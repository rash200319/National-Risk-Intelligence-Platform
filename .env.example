# MODEL-X environment template (safe placeholders only)

# Core runtime config
MODELX_DB_PATH=app/data/modelx.db
MODELX_REFRESH_INTERVAL=120
MODELX_FETCH_LIMIT=20
MODELX_AUTO_REFRESH_DEFAULT=true

# Optional external API keys
NEWS_API_KEY=
MASSIVE_API_KEY=
# NewsAPI is optional; if left blank, the app will fall back to RSS + GDELT automatically.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=# Backend
DATABASE_URL=sqlite:///./data/modelx.db
API_BASE_URL=http://localhost:8000

# Optional tuning for fallback coverage
# GDELT_QUERY="Sri Lanka"
# NEWSAPI_QUERIES="Sri Lanka,Colombo,Sri Lanka economy"
# HISTORICAL_LOOKBACK_DAYS=30
# GDELT_REQUEST_DELAY_SECONDS=2
# World Bank (no API key required)
WORLD_BANK_COUNTRY=LKA
WORLD_BANK_INDICATORS=FP.CPI.TOTL.ZG,NY.GDP.MKTP.KD.ZG,SL.UEM.TOTL.ZS

