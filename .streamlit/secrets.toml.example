# Copy this file to `.streamlit/secrets.toml` for local use,
# or paste the same keys/values into Streamlit Cloud -> App -> Settings -> Secrets.

MODELX_DB_PATH = "app/data/modelx.db"
MODELX_REFRESH_INTERVAL = 300
MODELX_FETCH_LIMIT = 20
MODELX_AUTO_REFRESH_DEFAULT = true

NEWS_API_KEY = "REPLACE_WITH_YOUR_NEWS_API_KEY"
MASSIVE_API_KEY = "REPLACE_WITH_YOUR_MASSIVE_API_KEY"

WORLD_BANK_COUNTRY = "LKA"
WORLD_BANK_INDICATORS = "FP.CPI.TOTL.ZG,NY.GDP.MKTP.KD.ZG,SL.UEM.TOTL.ZS"
